# Postgres (system of record)
DATABASE_URL=postgres://octo:octo-pass@localhost:5434/octo_db

# Redis (asynq broker + hot progress)
REDIS_ADDR=localhost:6379

# S3 / MinIO
S3_ENDPOINT=localhost:9100
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=octoconv
S3_USE_SSL=false

# API
API_ADDR=:8090
MAX_UPLOAD_BYTES=104857600   # 100 MiB -- deliberate global ceiling, kept as-is for now (Phase 31 Pitfall 3): an uncompressed 1-hour WAV (~635 MiB) exceeds this and returns a predictable 413, not a silent failure. A per-format/engine ceiling for long audio is deferred to Phase 32 alongside AUDIO_ENGINE_TIMEOUT's RTF-based sizing (duration and byte-size are correlated for a given bitrate); operators needing longer audio today can raise this env var globally as the interim lever.
MAX_IMAGE_PIXELS=100000000   # decompression-bomb guard: max declared width*height (default 100 megapixels, e.g. 10000x10000)
MAX_DOCUMENT_UNCOMPRESSED_BYTES=524288000   # zip-bomb guard: max total declared uncompressed size summed across all ZIP entries in an office document (default 500 MiB)
API_KEY_SALT=change-me-to-a-long-random-secret   # server-side pepper for API-key hashing (required)
RATE_LIMIT_IP_RPM=60   # coarse pre-auth IP flood guard, requests/min
RATE_LIMIT_CLIENT_RPM=120   # per-client requests/min
OPERATOR_CLIENT_IDS=   # comma-separated client UUIDs authorized for /v1/system/presets; empty/unset = no operators, fail-closed; parsed once at API startup, restart to change (D-01/OPER-01)

# Worker (image conversion; cmd/worker)
WORKER_CONCURRENCY=4
ENGINE_TIMEOUT=120s
IMAGE_MAX_RETRY=4   # small bounded retry budget for image conversion (D-05, smaller than webhook's 6); also feeds the derived per-job uniqueness-lock TTL together with ENGINE_TIMEOUT

# Webhook worker (cmd/webhook-worker; Phase 16 — sole webhook-delivery consumer and sole sweeper host)
WEBHOOK_WORKER_CONCURRENCY=4   # asynq concurrency for cmd/webhook-worker; mirrors WORKER_CONCURRENCY's default
WEBHOOK_SIGNING_SECRET=change-me-to-a-long-random-secret   # HMAC-SHA256 secret for signed webhook callbacks (required, webhook-worker-only — cmd/webhook-worker fails closed at startup if unset)
WEBHOOK_PRESIGN_TTL=6h   # presigned download_url lifetime per webhook delivery attempt (optional, default 6h; webhook-worker-only)
# WEBHOOK_ALLOW_INSECURE_HTTP / WEBHOOK_ALLOW_PRIVATE_IPS are API-side only:
# enforced by validateCallbackURL in the api process at job-creation time, not
# read by cmd/webhook-worker.
WEBHOOK_ALLOW_INSECURE_HTTP=false   # opt-in: allow webhook callback_url to use http (non-https) scheme (default false)
WEBHOOK_ALLOW_PRIVATE_IPS=false   # opt-in: allow webhook callback_url to target RFC1918 private-IP addresses; loopback/link-local/unspecified remain hard-blocked regardless (default false, D-01/D-02)

# Document worker
DOCUMENT_WORKER_CONCURRENCY=2   # lower than WORKER_CONCURRENCY's 4 — soffice.bin's heavier per-conversion memory footprint within the same cpus:2.0/memory:1g ceiling (D-02/D-03)
DOCUMENT_ENGINE_TIMEOUT=300s   # Phase 9 D-01
DOCUMENT_MAX_RETRY=3   # bounded retry budget for document conversion, mirrors IMAGE_MAX_RETRY; also feeds the derived per-job uniqueness-lock TTL together with DOCUMENT_ENGINE_TIMEOUT
VERAPDF_TIMEOUT=60s   # own timeout for the bundled veraPDF CLI validation call, separate from DOCUMENT_ENGINE_TIMEOUT (Phase 23 D-04); well inside the 300s document engine budget

# Chromium (html) worker
HTML_WORKER_CONCURRENCY=2   # chromium is heavier per-conversion than libvips/soffice; kept at the document-worker's concurrency ceiling
HTML_ENGINE_TIMEOUT=60s   # one-shot chromium --print-to-pdf is expected to be faster than a LibreOffice conversion (Phase 15 Plan 01)
HTML_MAX_RETRY=3   # bounded retry budget for html conversion, mirrors DOCUMENT_MAX_RETRY; also feeds the derived per-job uniqueness-lock TTL together with HTML_ENGINE_TIMEOUT

# Audio worker (cmd/audio-worker; Phase 31)
AUDIO_ENGINE_TIMEOUT=600s   # [ASSUMED] placeholder only -- Phase 32 re-derives this from measured RTF (real-time factor) against the pinned whisper-cli/model; do NOT treat as tuned, and do NOT copy DOCUMENT_ENGINE_TIMEOUT's 300s verbatim (whisper transcription is expected to run far longer than a LibreOffice conversion)
AUDIO_MAX_RETRY=3   # bounded retry budget for audio conversion, mirrors DOCUMENT_MAX_RETRY/HTML_MAX_RETRY; also feeds the derived per-job uniqueness-lock TTL together with AUDIO_ENGINE_TIMEOUT (AudioUniqueTTL, Phase 31)
AUDIO_WORKER_CONCURRENCY=2   # mirrors DOCUMENT_WORKER_CONCURRENCY/HTML_WORKER_CONCURRENCY; Phase 32 re-sizes from measured per-job RSS (whisper.cpp threads sized to cgroup CPU limit, not host core count)
AUDIO_MAX_DURATION_SECONDS=14400   # 4h ceiling on declared audio duration (ffprobe-enforced, EnforceMaxDuration, fail-closed) -- guards against pathologically long/adversarial inputs independent of MAX_UPLOAD_BYTES. Accepts bare integer seconds ("14400", as the name advertises) OR Go duration syntax ("4h"/"14400s"); an unparseable value logs a warning and falls back to the 4h default (WR-05)
AUDIO_MODEL_PATH=/models/ggml-base.bin   # whisper.cpp model path passed to whisper-cli -m; local-dev override example: ~/.cache/whisper/ggml-base.bin (Phase 30-provisioned). Container path (Phase 32 bake-in target): /models/ggml-base.bin. Never derived from client input (T-30-10) -- operator-set process env only.

# Reconciler (webhook-worker-only as of Phase 16 — the sweeper runs solely in
# cmd/webhook-worker, lock-gated by a Postgres advisory lock so exactly one
# replica sweeps at a time; D-04)
RECONCILER_QUEUED_STALE_AFTER=90s   # lost-enqueue queued threshold (D-08)
RECONCILER_ACTIVE_STALE_AFTER=15m   # crashed-worker active threshold; raised from 5m (Phase 31, Pitfall 2 option 1) so it comfortably exceeds AUDIO_ENGINE_TIMEOUT's placeholder budget. This is a GLOBAL threshold (one column, all engine classes) -- raising it for audio also raises image/document/html staleness-detection latency (image/document were previously covered/exactly-covered at the old 5m default). Accepted deliberately: the enqueue-first + asynq.ErrDuplicateTask guard (proven by TestSweepSkipsDuplicateEnqueue) is the actual double-processing safety mechanism, not this threshold -- this value only controls how soon the reconciler *attempts* recovery. A per-engine override (Config shape change) was considered and deferred as a larger, more invasive refactor (STATE.md AudioUniqueTTL decision).
RECONCILER_SWEEP_INTERVAL=1m   # fixed sweep tick interval (D-10)
RECONCILER_MAX_RECOVERIES=3   # recovery cap before a job is marked reconciler_exhausted (D-12)

# Storage lifecycle
STORAGE_TTL=168h   # single TTL for uploads/ and results/ prefixes, default 7 days; MinIO expiration is whole-day granular (D-10/D-11/D-12)

# Observability
METRICS_ADDR=127.0.0.1:9090   # localhost-only Prometheus /metrics listener, separate from API_ADDR; run api+worker on one host with distinct values (D-19)
