# Postgres (system of record)
DATABASE_URL=postgres://octo:octo-pass@localhost:5433/octo_db

# Redis (asynq broker + hot progress)
REDIS_ADDR=localhost:6379

# S3 / MinIO
S3_ENDPOINT=localhost:9100
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=octoconv
S3_USE_SSL=false

# API
API_ADDR=:8080
MAX_UPLOAD_BYTES=104857600   # 100 MiB

# Worker
WORKER_CONCURRENCY=4
ENGINE_TIMEOUT=120s
