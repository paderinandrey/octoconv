# Postgres (system of record)
DATABASE_URL=postgres://octo:octo-pass@localhost:5434/octo_db

# Redis (asynq broker + hot progress)
REDIS_ADDR=localhost:6379

# S3 / MinIO
S3_ENDPOINT=localhost:9100
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=octoconv
S3_USE_SSL=false

# API
API_ADDR=:8090
MAX_UPLOAD_BYTES=2147483648   # 2 GiB -- D-07 (Phase 35, operator-confirmed 2026-07-21): raised from the prior 100 MiB so video uploads are admissible. This is a pre-parse http.MaxBytesReader bound, enforced BEFORE the engine class is known, so it alone cannot distinguish a legitimate 1 GiB video from a 1 GiB image. A SECOND, per-engine ceiling (internal/api's D-07 MaxEngineBytes, not env-configurable) runs immediately AFTER content-type detection and holds image/document/html/audio at their prior 100 MiB effective bound -- the raise here does not weaken their DoS posture, only the av engine class gains the larger allowance.
MAX_IMAGE_PIXELS=100000000   # decompression-bomb guard: max declared width*height (default 100 megapixels, e.g. 10000x10000)
MAX_DOCUMENT_UNCOMPRESSED_BYTES=524288000   # zip-bomb guard: max total declared uncompressed size summed across all ZIP entries in an office document (default 500 MiB)
API_KEY_SALT=change-me-to-a-long-random-secret   # server-side pepper for API-key hashing (required)
RATE_LIMIT_IP_RPM=60   # coarse pre-auth IP flood guard, requests/min
RATE_LIMIT_CLIENT_RPM=120   # per-client requests/min
OPERATOR_CLIENT_IDS=   # comma-separated client UUIDs authorized for /v1/system/presets; empty/unset = no operators, fail-closed; parsed once at API startup, restart to change (D-01/OPER-01)

# Worker (image conversion; cmd/worker)
WORKER_CONCURRENCY=4
ENGINE_TIMEOUT=120s
IMAGE_MAX_RETRY=4   # small bounded retry budget for image conversion (D-05, smaller than webhook's 6); also feeds the derived per-job uniqueness-lock TTL together with ENGINE_TIMEOUT

# Webhook worker (cmd/webhook-worker; Phase 16 — sole webhook-delivery consumer and sole sweeper host)
WEBHOOK_WORKER_CONCURRENCY=4   # asynq concurrency for cmd/webhook-worker; mirrors WORKER_CONCURRENCY's default
WEBHOOK_SIGNING_SECRET=change-me-to-a-long-random-secret   # HMAC-SHA256 secret for signed webhook callbacks (required, webhook-worker-only — cmd/webhook-worker fails closed at startup if unset)
WEBHOOK_PRESIGN_TTL=6h   # presigned download_url lifetime per webhook delivery attempt (optional, default 6h; webhook-worker-only)
# WEBHOOK_ALLOW_INSECURE_HTTP / WEBHOOK_ALLOW_PRIVATE_IPS are API-side only:
# enforced by validateCallbackURL in the api process at job-creation time, not
# read by cmd/webhook-worker.
WEBHOOK_ALLOW_INSECURE_HTTP=false   # opt-in: allow webhook callback_url to use http (non-https) scheme (default false)
WEBHOOK_ALLOW_PRIVATE_IPS=false   # opt-in: allow webhook callback_url to target RFC1918 private-IP addresses; loopback/link-local/unspecified remain hard-blocked regardless (default false, D-01/D-02)

# Document worker
DOCUMENT_WORKER_CONCURRENCY=2   # lower than WORKER_CONCURRENCY's 4 — soffice.bin's heavier per-conversion memory footprint within the same cpus:2.0/memory:1g ceiling (D-02/D-03)
DOCUMENT_ENGINE_TIMEOUT=300s   # Phase 9 D-01
DOCUMENT_MAX_RETRY=3   # bounded retry budget for document conversion, mirrors IMAGE_MAX_RETRY; also feeds the derived per-job uniqueness-lock TTL together with DOCUMENT_ENGINE_TIMEOUT
VERAPDF_TIMEOUT=60s   # own timeout for the bundled veraPDF CLI validation call, separate from DOCUMENT_ENGINE_TIMEOUT (Phase 23 D-04); well inside the 300s document engine budget

# Chromium (html) worker
HTML_WORKER_CONCURRENCY=2   # chromium is heavier per-conversion than libvips/soffice; kept at the document-worker's concurrency ceiling
HTML_ENGINE_TIMEOUT=60s   # one-shot chromium --print-to-pdf is expected to be faster than a LibreOffice conversion (Phase 15 Plan 01)
HTML_MAX_RETRY=3   # bounded retry budget for html conversion, mirrors DOCUMENT_MAX_RETRY; also feeds the derived per-job uniqueness-lock TTL together with HTML_ENGINE_TIMEOUT

# Audio worker (cmd/audio-worker; Phase 31)
AUDIO_ENGINE_TIMEOUT=742s   # Phase 32 AUD-07: RTF-measured (scripts/audio-rtf-measure.sh, p95 RTF=0.205853, N=10, arm64, base model, 2-cpu/1g container), timeout = ceil(AUDIO_MAX_DURATION_SECONDS x RTF_p95 x 2.0 safety factor) = ceil(1800 x 0.205853 x 2.0) = 742s (17.6% margin under the 900s/15m reconciler CAP, 32-03-SUMMARY.md). MUST be set identically in the api, worker, document-worker, chromium-worker, webhook-worker, and audio-worker environments -- the uniqueness-lock TTL (audioUniqueTTL) is derived from these values in every enqueuing process (IN-02).
AUDIO_MAX_RETRY=3   # bounded retry budget for audio conversion, mirrors DOCUMENT_MAX_RETRY/HTML_MAX_RETRY; also feeds the derived per-job uniqueness-lock TTL together with AUDIO_ENGINE_TIMEOUT (AudioUniqueTTL, Phase 31). Must also be set identically across all 7 queue.NewClient()-constructing services (IN-02).
AUDIO_WORKER_CONCURRENCY=1   # Phase 32 AUD-07: measured, not assumed -- single-job peak RSS (~728.4 MiB of the 1g limit) makes concurrency=2 exceed both the memory limit (2x728.4=1456.8 MiB > 1024 MiB) and the cpu quota (-t 2 already consumes the full 2.0-cpu budget per job); see 32-03-SUMMARY.md.
AUDIO_MAX_DURATION_SECONDS=1800   # 30min ceiling on declared audio duration (ffprobe-enforced, EnforceMaxDuration, fail-closed) -- lowered from the 14400s (4h) placeholder via Phase 32's documented NO-GO lever: the 4h ceiling's RTF-derived timeout (1349s) breached the 900s/15m reconciler CAP, so the duration ceiling was lowered instead of inflating the timeout or the global CAP (32-03-SUMMARY.md). Accepts bare integer seconds ("1800", as the name advertises) OR Go duration syntax ("30m"/"1800s"); an unparseable value logs a warning and falls back to the 4h default (WR-05)
# AUDIO_MODEL_PATH: whisper.cpp model path passed to whisper-cli -m;
# local-dev override example: ~/.cache/whisper/ggml-base.bin
# (Phase 30-provisioned). Container path (Phase 32 bake-in target):
# /models/ggml-base.bin. Never derived from client input (T-30-10) --
# operator-set process env only. Comment kept on its own lines (WR-06):
# non-shell env-file loaders (docker --env-file, compose env_file:, k8s
# configmaps) do not strip inline comments; cmd/audio-worker additionally
# strips a trailing " # comment" defensively (stripInlineComment).
AUDIO_MODEL_PATH=/models/ggml-base.bin
# AUDIO_THREADS: OPTIONAL operator escape hatch for whisper-cli's -t flag.
# Default unset -- auto-detected at cmd/audio-worker startup from the
# container's real cgroup v2 CPU quota (/sys/fs/cgroup/cpu.max, floored
# quota/period), falling back to the host's core count (runtime.NumCPU())
# outside a container (e.g. local `go run` dev flow) or on a cgroup v1 host.
# whisper-cli's own built-in default is host core count, which under a
# container CPU limit causes CFS throttling / unpredictable wall time rather
# than reflecting the container's real budget (T-32-04, PITFALLS.md
# Pitfall 5) -- this is why an explicit -t is always passed, never left to
# whisper-cli itself. If set, this value should match the thread count used
# for the phase's RTF (real-time factor) measurement -- changing it after
# the fact invalidates that measurement's timeout/concurrency sizing.
AUDIO_THREADS=

# AV worker (cmd/av-worker; Phase 35/36). Compose service + CI bake matrix
# entry landed in Phase 36 Plan 03; the container image is Phase 36 Plan 02.
AV_ENGINE_TIMEOUT=600s   # [ASSUMED] provisional default, mirroring AUDIO_ENGINE_TIMEOUT's original 600s placeholder (600s -> 742s after Phase 32's RTF measurement); FINALIZED BY PLAN 04's supervised scripts/av-rtf-measure.sh matrix run (AVE-04), not yet measured as of this Plan 03. MUST be set identically in every queue.NewClient()-constructing service (api + all workers) -- AVUniqueTTL is derived from it in each enqueuing process (IN-02), and a mismatch silently produces duplicate processing. Coupled to RECONCILER_ACTIVE_STALE_AFTER (global 900s default below): raising this toward 900s requires raising that threshold in the same change (this near-broke the audio engine once, 32-03-SUMMARY.md).
AV_MAX_RETRY=2   # LOCKED at 2 per Phase 35 D-03 (fewer attempts, longer 30s/2m backoff -- transcode is the project's most expensive operation, so a busy worker should drain rather than be hammered). Also feeds AVUniqueTTL together with AV_ENGINE_TIMEOUT; must be set identically across all queue.NewClient()-constructing services (IN-02).
AV_WORKER_CONCURRENCY=2   # transcode is CPU-bound; provisional -- FINALIZED BY PLAN 04's measurement (mirrors AUDIO_WORKER_CONCURRENCY's Phase 32 measured-not-assumed provenance), not yet measured as of this Plan 03.
AV_MAX_DURATION_SECONDS=14400   # 4h ceiling on declared video duration (ffprobe-enforced, EnforceMaxDuration, fail-closed; av.go's const default) -- av-worker-only, NOT read by queue.NewClient() so it does not need IN-02 parity. This is the NO-GO lever: if Plan 04's measured AV_ENGINE_TIMEOUT would otherwise breach the 900s/15m reconciler CAP, this value is lowered instead of inflating the timeout or the global CAP (mirrors AUDIO_MAX_DURATION_SECONDS's Phase 32 precedent, 32-03-SUMMARY.md). Accepts bare integer seconds ("14400") OR Go duration syntax ("4h"/"14400s"); an unparseable or negative value logs a warning and falls back to the 4h default (envDurationSeconds, cmd/av-worker/main.go).
AV_DISK_SAFETY_FACTOR=3.0   # [ASSUMED] proportional disk-guard multiplier: EnforceMinFreeDisk requires (inputSizeBytes x this factor) bytes of available disk before dispatching ffmpeg (D-06, Phase 36 Plan 01) -- no measured decode/encode disk-usage ratio existed to derive a better default from at Plan 01 time. Positive float only; a set-but-non-positive or unparseable value logs a warning and falls back to 3.0 (envFloat, cmd/av-worker/main.go).

# Reconciler (webhook-worker-only as of Phase 16 — the sweeper runs solely in
# cmd/webhook-worker, lock-gated by a Postgres advisory lock so exactly one
# replica sweeps at a time; D-04)
RECONCILER_QUEUED_STALE_AFTER=90s   # lost-enqueue queued threshold (D-08)
RECONCILER_ACTIVE_STALE_AFTER=15m   # crashed-worker active threshold; raised from 5m (Phase 31, Pitfall 2 option 1) so it comfortably exceeds AUDIO_ENGINE_TIMEOUT's placeholder budget. This is a GLOBAL threshold (one column, all engine classes) -- raising it for audio also raises image/document/html staleness-detection latency (image/document were previously covered/exactly-covered at the old 5m default). Accepted deliberately: the enqueue-first + asynq.ErrDuplicateTask guard (proven by TestSweepSkipsDuplicateEnqueue) is the actual double-processing safety mechanism, not this threshold -- this value only controls how soon the reconciler *attempts* recovery. A per-engine override (Config shape change) was considered and deferred as a larger, more invasive refactor (STATE.md AudioUniqueTTL decision).
RECONCILER_SWEEP_INTERVAL=1m   # fixed sweep tick interval (D-10)
RECONCILER_MAX_RECOVERIES=3   # recovery cap before a job is marked reconciler_exhausted (D-12)

# Storage lifecycle
STORAGE_TTL=168h   # single TTL for uploads/ and results/ prefixes, default 7 days; MinIO expiration is whole-day granular (D-10/D-11/D-12)

# Observability
METRICS_ADDR=127.0.0.1:9090   # localhost-only Prometheus /metrics listener, separate from API_ADDR; run api+worker on one host with distinct values (D-19)
